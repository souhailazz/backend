{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:59985",
      "sslPort": 44384
    }
  },
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessage": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "http://*:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "PORT": "5000"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "https://*:7146;http://*:5000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "PORT": "5000"
      }
    },
    "Railway": {
      "commandName": "Project",
      "launchBrowser": false,
      "applicationUrl": "http://*:${PORT}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Production",
        "PORT": "${PORT}"
      }
    }
  }
}
